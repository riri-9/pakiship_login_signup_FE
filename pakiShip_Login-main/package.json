{
  "name": "pakishipmobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "node scripts/clear-tunnel.js && expo start",
    "dev": "node scripts/start-with-tunnel.js",
    "ngrok": "expo start --tunnel",
    "clear": "node scripts/clear-tunnel.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "tunnel": "expo start --tunnel -c",
    "lt": "lt --port 8081 --subdomain pakiship-customer-v3",
    "start:lt": "npx -y kill-port 8081 && concurrently --raw \"npx expo start\" \"npx wait-on tcp:8081 && npm run lt\"",
    "postinstall": "node scripts/ensure-detox-jest-compat.ts",
    "verify": "npm run lint && npm run test",
    "lint": "npx eslint . --max-warnings=0",
    "test": "npx jest --coverage --verbose --ci --forceExit --runInBand",
    "detox:build": "npx detox build -c android.emu.debug",
    "detox:test": "npx detox test -c android.emu.debug --headless",
    "detox:build:ios": "npx detox build -c ios.sim.debug",
    "detox:test:ios": "npx detox test -c ios.sim.debug --cleanup"
  },
  "dependencies": {
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.13",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^1.7.0",
    "nativewind": "^2.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-refresh": "^0.18.0"
  },
  "private": true,
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "@types/react-native": "^0.72.8",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~54.0.10",
    "concurrently": "^9.2.1",
    "detox": "^20.50.1",
    "eslint": "^8.57.1",
    "eslint-config-expo": "^55.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "localtunnel": "^2.0.2",
    "postcss": "8.4.23",
    "tailwindcss": "3.3.2",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2",
    "wait-on": "^9.0.4"
  },
  "detox": {
    "testRunner": {
      "args": {
        "$0": "jest",
        "config": "tests/e2e/jest.config.ts"
      },
      "jest": {
        "setupTimeout": 120000
      }
    },
    "apps": {
      "android.debug": {
        "type": "android.apk",
        "binaryPath": "android/app/build/outputs/apk/debug/app-debug.apk",
        "build": "cd android && ./gradlew assembleDebug assembleAndroidTest -DtestBuildType=debug"
      },
      "ios.debug": {
        "type": "ios.app",
        "binaryPath": "ios/build/Build/Products/Debug-iphonesimulator/pakishipmobile.app",
        "build": "xcodebuild -workspace ios/pakishipmobile.xcworkspace -scheme pakishipmobile -configuration Debug -sdk iphonesimulator -derivedDataPath ios/build"
      }
    },
    "devices": {
      "emulator": {
        "type": "android.emulator",
        "device": {
          "avdName": "Pixel_3a_API_30_x86"
        }
      },
      "simulator": {
        "type": "ios.simulator",
        "device": {
          "type": "iPhone 14"
        }
      }
    },
    "configurations": {
      "android.emu.debug": {
        "device": "emulator",
        "app": "android.debug"
      },
      "ios.sim.debug": {
        "device": "simulator",
        "app": "ios.debug"
      }
    }
  }
}
