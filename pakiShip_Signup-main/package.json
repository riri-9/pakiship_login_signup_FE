{
  "name": "pakishipmobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "node scripts/clear-tunnel.js && expo start",
    "dev": "node scripts/start-with-tunnel.js",
    "ngrok": "node scripts/clear-tunnel.js && expo start --tunnel",
    "clear": "node scripts/clear-tunnel.js",
    "start:tunnel": "node scripts/start-with-tunnel.js",
    "postinstall": "node scripts/ensure-detox-jest-compat.js",
    "verify": "npm run lint && npm run test",
    "lint": "eslint . --max-warnings=0",
    "test": "jest --coverage --verbose --ci --forceExit --runInBand",
    "detox:build": "detox build -c android.emu.debug",
    "detox:test": "detox test -c android.emu.debug --headless",
    "detox:build:ios": "detox build -c ios.sim.debug",
    "detox:test:ios": "detox test -c ios.sim.debug --cleanup",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.13",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^1.7.0",
    "nativewind": "^2.0.11",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-refresh": "^0.18.0",
    "react-dom": "19.1.0"
  },
  "private": true,
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "@types/react-native": "^0.72.8",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~54.0.10",
    "concurrently": "^9.2.1",
    "detox": "^20.50.1",
    "eslint": "^8.57.1",
    "eslint-config-expo": "^55.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "localtunnel": "^2.0.2",
    "postcss": "8.4.23",
    "tailwindcss": "3.3.2",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2",
    "wait-on": "^9.0.4"
  }
}
